@model practice1.Models.User
@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>

    body {
        background: linear-gradient(135deg,#4F46E5,#7C3AED,#9333EA);
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        font-family: 'Segoe UI',sans-serif;
    }

    .register-container {
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 30px;
    }

    .register-card {
        width: 450px;
        background: rgba(255,255,255,.15);
        backdrop-filter: blur(15px);
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 15px 35px rgba(0,0,0,.3);
        color: white;
    }

        .register-card h2 {
            text-align: center;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .register-card p {
            text-align: center;
            color: #ececec;
            margin-bottom: 30px;
        }

    .form-label {
        font-weight: 600;
    }

    .input-group-text {
        border: none;
        background: white;
    }

    .form-control {
        border: none;
        height: 48px;
    }

        .form-control:focus {
            box-shadow: none;
            border: 2px solid #6C63FF;
        }

    .btn-register {
        width: 100%;
        height: 48px;
        border: none;
        border-radius: 10px;
        background: white;
        color: #6C63FF;
        font-weight: bold;
        transition: .3s;
    }

        .btn-register:hover {
            background: #6C63FF;
            color: white;
            transform: translateY(-2px);
        }

    .login-link {
        margin-top: 25px;
        text-align: center;
    }

        .login-link a {
            background: linear-gradient(135deg,#FF6B6B,#FF8E53);
            color: white;
            padding: 8px 18px;
            border-radius: 25px;
            text-decoration: none;
            font-weight: 600;
            margin-left: 8px;
            transition: .3s;
        }

            .login-link a:hover {
                color: white;
                transform: translateY(-2px);
            }

    .alert {
        border-radius: 10px;
    }

    .footer {
        margin-top: 25px;
        text-align: center;
        color: #f2f2f2;
        font-size: 14px;
    }

</style>

<div class="register-container">

    <div class="register-card">

        <h2>
            <i class="bi bi-person-plus-fill"></i>
            Create Account
        </h2>

        <p>Join us by creating your account</p>

        <form asp-action="Register" method="post">

            <div class="mb-3">

                <label class="form-label">Username</label>

                <div class="input-group">

                    <span class="input-group-text">
                        <i class="bi bi-person-fill"></i>
                    </span>

                    <input asp-for="Username"
                           class="form-control"
                           placeholder="Enter Username" />

                </div>

            </div>

            <div class="mb-3">

                <label class="form-label">Password</label>

                <div class="input-group">

                    <span class="input-group-text">
                        <i class="bi bi-lock-fill"></i>
                    </span>

                    <input asp-for="Password"
                           type="password"
                           class="form-control"
                           placeholder="Enter Password" />

                </div>

            </div>

            <div class="mb-3">

                <label class="form-label">Confirm Password</label>

                <div class="input-group">

                    <span class="input-group-text">
                        <i class="bi bi-shield-lock-fill"></i>
                    </span>

                    <input asp-for="ConfirmPassword"
                           type="password"
                           class="form-control"
                           placeholder="Confirm Password" />

                </div>

            </div>

            @if (ViewBag.Message != null)
            {
                <div class="alert alert-danger text-center">
                    @ViewBag.Message
                </div>
            }

            <button type="submit"
                    class="btn btn-register">

                <i class="bi bi-person-check-fill"></i>
                Register

            </button>

            <div class="login-link">

                Already have an account?

                <a asp-action="Login"
                   asp-controller="Login">

                    Login

                </a>

            </div>

        </form>

        <div class="footer">

            © 2026  <br />

            Developed with ❤️ using ASP.NET Core MVC

        </div>

    </div>

</div>